---
const currentYear = new Date().getFullYear();

const socialLinks = [
  { href: 'https://github.com/abbluiz', label: 'GitHub' },
  { href: 'https://mastodon.social/@abbluiz', label: 'Mastodon', rel: 'me' },
  { href: 'mailto:contact@labb.email', label: 'Email' },
  { href: '/rss.xml', label: 'RSS' },
];
---

<footer class="site-footer">
  <div class="container container--wide footer-inner">
    <p class="footer-copy">
      🄯 {currentYear} LABB —
      <a href="https://creativecommons.org/licenses/by/4.0/" target="_blank" rel="noopener">CC BY 4.0</a>
    </p>

    <nav aria-label="Links sociais">
      <ul class="footer-links">
        {socialLinks.map(({ href, label, rel }) => (
          <li>
            <a href={href} rel={rel ?? 'noopener noreferrer'} target={href.startsWith('mailto') || href.startsWith('/') ? undefined : '_blank'}>
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding-block: 1.5rem;
    margin-top: 4rem;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .footer-copy {
    font-size: 0.85rem;
    color: var(--color-muted);
    margin: 0;
  }

  .footer-copy a {
    color: var(--color-muted);
  }

  .footer-copy a:hover {
    color: var(--color-primary);
  }

  .footer-links {
    list-style: none;
    display: flex;
    gap: 1.25rem;
  }

  .footer-links a {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-links a:hover {
    color: var(--color-primary);
  }

  @media (max-width: 480px) {
    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }

    .footer-links {
      gap: 1rem;
      flex-wrap: wrap;
    }
  }
</style>
