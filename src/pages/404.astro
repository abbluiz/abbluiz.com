---
import Base from '../layouts/Base.astro';
---

<Base title="404 — Página não encontrada — LABB" description="Esta página não existe.">
  <div class="container container--wide page">
    <p class="code">404</p>
    <h1>Página não encontrada</h1>
    <p class="desc">O endereço que você acessou não existe ou foi movido.</p>
    <a href="/" class="back-link">← Voltar ao início</a>
  </div>
</Base>

<style>
  .page {
    padding-block: 6rem 5rem;
  }

  .code {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--color-primary);
    margin-bottom: 1rem;
    letter-spacing: 0.1em;
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
  }

  .desc {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    color: var(--color-muted);
    margin-bottom: 2rem;
  }

  .back-link {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .back-link:hover {
    color: var(--color-primary);
  }
</style>
