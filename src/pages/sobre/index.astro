---
import Base from '../../layouts/Base.astro';
---

<Base title="Sobre — LABB" description="Sobre mim e este site.">
  <div class="container page">
    <header class="page-header">
      <h1>Sobre</h1>
    </header>

    <div class="prose">
      <h2>Olá</h2>
      <p>
        Sou Luiz Antonio Bueno Barbosa (LABB), desenvolvedor de software.
        <!-- Escreva aqui -->
      </p>

      <h2>Este site</h2>
      <p>
        Construído com <a href="https://astro.build" target="_blank" rel="noopener">Astro</a>.
        O código está disponível no <a href="https://github.com/abbluiz/abbluiz.com" target="_blank" rel="noopener">GitHub</a>
        sob licença MIT. O conteúdo é licenciado sob <a href="https://creativecommons.org/licenses/by/4.0/" target="_blank" rel="noopener">CC BY 4.0</a>.
      </p>
    </div>
  </div>
</Base>

<style>
  .page {
    padding-block: 3rem 4rem;
  }

  .page-header {
    margin-bottom: 3rem;
  }

  .page-header h1 {
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  /* Estilos de prosa para texto corrido */
  .prose {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    line-height: 1.8;
    max-width: 65ch;
  }

  .prose h2 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .prose h2:first-child {
    margin-top: 0;
  }

  .prose a {
    color: var(--color-primary);
  }
</style>
