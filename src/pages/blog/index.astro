---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';

const posts = (await getCollection('blog', ({ data }) => !data.rascunho))
  .sort((a, b) => b.data.publicado.valueOf() - a.data.publicado.valueOf());
---

<Base title="Blog — LABB" description="Posts sobre desenvolvimento, segurança, privacidade e mais.">
  <div class="container page">
    <header class="page-header">
      <h1>Blog</h1>
      <p class="page-lead">Desenvolvimento, segurança, privacidade — e às vezes política e cotidiano.</p>
    </header>

    {posts.length > 0 ? (
      <div class="post-list">
        {posts.map(post => <PostCard post={post} />)}
      </div>
    ) : (
      <p class="empty">Nenhum post publicado ainda. Em breve!</p>
    )}
  </div>
</Base>

<style>
  .page {
    padding-block: 3rem 4rem;
  }

  .page-header {
    margin-bottom: 3rem;
  }

  .page-header h1 {
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }

  .page-lead {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    color: var(--color-muted);
    margin: 0;
  }

  .empty {
    color: var(--color-muted);
    font-family: var(--font-serif);
    font-style: italic;
  }
</style>
